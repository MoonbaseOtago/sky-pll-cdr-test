VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN tt_um_template ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 130000 47000 ) ;
COMPONENTS 0 ;
END COMPONENTS
PINS 29 ;
    - CLK + NET CLK + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -150 -500 ) ( 150 500 )
        + PLACED ( 53500 500 ) S ;
    - RESET_N + NET RESET_N + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -150 -500 ) ( 150 500 )
        + PLACED ( 55200 500 ) S ;

    - XMT_READY + NET XMT_READY + DIRECTION INPUT + USE SIGNAL
