SPECIALNETS 2 ;
    - VGND + USE GROUND ;
    - VPWR + USE POWER ;
END SPECIALNETS
NETS 29 ;
    - CLK ( PIN CLK ) + USE SIGNAL ;
    - RESET_N ( PIN RESET_N ) + USE SIGNAL ;
    - RESTART ( PIN RESTART ) + USE SIGNAL ;
    - DIN ( PIN DIN ) + USE SIGNAL ;
    - REV ( PIN REV ) + USE SIGNAL ;
    - CLK10 ( PIN CLK10 ) + USE SIGNAL ;
    - DOUT ( PIN DOUT ) + USE SIGNAL ;
    - XMT_READY ( PIN XMT_READY ) + USE SIGNAL ;
