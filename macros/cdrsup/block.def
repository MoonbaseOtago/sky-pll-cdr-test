    - DI[2] ( PIN DI[2] ) + USE SIGNAL ;
    - DI[3] ( PIN DI[3] ) + USE SIGNAL ;
    - DI[4] ( PIN DI[4] ) + USE SIGNAL ;
    - DI[5] ( PIN DI[5] ) + USE SIGNAL ;
    - DI[6] ( PIN DI[6] ) + USE SIGNAL ;
    - DI[7] ( PIN DI[7] ) + USE SIGNAL ;
    - DI[8] ( PIN DI[8] ) + USE SIGNAL ;
    - DI[9] ( PIN DI[9] ) + USE SIGNAL ;
