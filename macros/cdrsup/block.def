    - DO[7] ( PIN DO[7] ) + USE SIGNAL ;
    - DO[8] ( PIN DO[8] ) + USE SIGNAL ;
    - DO[9] ( PIN DO[9] ) + USE SIGNAL ;
    - DI[0] ( PIN DI[0] ) + USE SIGNAL ;
