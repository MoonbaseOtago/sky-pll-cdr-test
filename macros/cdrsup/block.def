VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN tt_um_template ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 77000 60000 ) ;
COMPONENTS 0 ;
END COMPONENTS
PINS 35 ;
    - CLKI + NET CLKI + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -150 -500 ) ( 150 500 )
        + PLACED ( 13120 500 ) S ;
    - CLKI_N + NET CLKI_N + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -150 -500 ) ( 150 500 )
        + PLACED ( 14420 500 ) S ;
