SPECIALNETS 2 ;
    - VGND + USE GROUND ;
    - VPWR + USE POWER ;
END SPECIALNETS
NETS 35 ;
    - CLKI ( PIN CLKI ) + USE SIGNAL ;
    - CLKI_N ( PIN CLKI_N ) + USE SIGNAL ;
    - CLKQ ( PIN CLKQ ) + USE SIGNAL ;
    - CLKQ_N ( PIN CLKQ_N ) + USE SIGNAL ;
    - UP_N ( PIN UP_N ) + USE SIGNAL ;
    - DOWN_N ( PIN DOWN_N ) + USE SIGNAL ;
    - RESET_N ( PIN RESET_N ) + USE SIGNAL ;
    - RESTART ( PIN RESTART ) + USE SIGNAL ;
    - RESET ( PIN RESET ) + USE SIGNAL ;
    - DIN ( PIN DIN ) + USE SIGNAL ;
    - REV ( PIN REV ) + USE SIGNAL ;
    - CLK10 ( PIN CLK10 ) + USE SIGNAL ;
    - DOUT ( PIN DOUT ) + USE SIGNAL ;
    - XMT_READY ( PIN XMT_READY ) + USE SIGNAL ;
    - XMT_RD ( PIN XMT_RD ) + USE SIGNAL ;
    - DO[0] ( PIN DO[0] ) + USE SIGNAL ;
